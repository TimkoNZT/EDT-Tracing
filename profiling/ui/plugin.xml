<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
	<extension point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            category="com._1c.g5.v8.dt.ui.v8category"
            class="com._1c.g5.v8.dt.internal.profiling.ui.ProfilingUIExecutableExtensionFactory:com._1c.g5.v8.dt.internal.profiling.ui.view.ProfilingView"
            icon="icons/etool16/profiling.png"
            id="com._1c.g5.v8.dt.profiling.ui.view.ProfilingView"
            name="%view.profiling.name">
      </view>
      <view
            allowMultiple="true"
            class="com._1c.g5.v8.dt.internal.profiling.ui.ProfilingUIExecutableExtensionFactory:com._1c.g5.v8.dt.internal.profiling.ui.compare.view.CompareView"
            icon="icons/elcl16/compare_view.gif"
            id="com._1c.g5.v8.dt.profiling.ui.compare.view"
            name="%view.profiling.compare.name"
            restorable="false">
      </view>
  </extension>
  <extension point="org.eclipse.ui.commands">
  	<command
	   id="com._1c.g5.v8.dt.profiling.ui.view.commands.profiling"
	   name="%command.profiling.name">
	   <state
	         class="org.eclipse.ui.handlers.RegistryToggleState"
            id="org.eclipse.ui.commands.toggleState">
	   </state>
    </command>
   <command
         id="com._1c.g5.v8.dt.profiling.ui.showOutdatedResults"
         name="%ruler.command.showOutdatedResults">
      <state
            class="org.eclipse.ui.handlers.RegistryToggleState"
            id="org.eclipse.ui.commands.toggleState">
      </state>
   </command>
   <command
         id="com._1c.g5.v8.dt.profiling.ui.showRuler"
         name="%ruler.command.showRuler">
      <state
            class="org.eclipse.ui.handlers.RegistryToggleState"
            id="org.eclipse.ui.commands.toggleState">
      </state>
   </command>
  </extension>
  <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="toolbar:org.eclipse.debug.ui.breakpointActionSet">
         <command
               commandId="com._1c.g5.v8.dt.profiling.ui.view.commands.profiling"
               icon="icons/etool16/profiling.png"
               label="%command.profiling.name"
               style="toggle">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.run?after=breakpointGroup">
         <separator
               name="com._1c.g5.v8.dt.profiling.ui.separator"
               visible="true">
         </separator>
         <command
               commandId="com._1c.g5.v8.dt.profiling.ui.view.commands.profiling"
               icon="icons/etool16/profiling.png"
               label="%command.profiling.name"
               style="toggle">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:#TextRulerContext?before=QuickDiff.Toggle">
         <menu
               icon="icons/etool16/profiling.png"
               label="%command.profiling.name">
            <command
                  commandId="com._1c.g5.v8.dt.profiling.ui.showRuler"
                  label="%ruler.command.showRuler"
                  style="toggle">
                  </command>
                  <command
                  commandId="com._1c.g5.v8.dt.profiling.ui.showOutdatedResults"
                  label="%ruler.command.showOutdatedResults"
                  style="toggle">
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="com._1c.g5.v8.dt.internal.profiling.ui.ProfilingUIExecutableExtensionFactory:com._1c.g5.v8.dt.internal.profiling.ui.ToggleProfilingHandler"
            commandId="com._1c.g5.v8.dt.profiling.ui.view.commands.profiling">
      </handler>
      <handler
            class="com._1c.g5.v8.dt.internal.profiling.ui.ruler.OutdatedResultsHandler"
            commandId="com._1c.g5.v8.dt.profiling.ui.showOutdatedResults">
            <enabledWhen>
               <with
                     variable="com._1c.g5.v8.dt.profiling.ui.showOutdatedResults.active">
                  <equals
                        value="true">
                  </equals>
               </with>
            </enabledWhen>
      </handler>
      <handler
            class="com._1c.g5.v8.dt.internal.profiling.ui.ShowRulerHandler"
            commandId="com._1c.g5.v8.dt.profiling.ui.showRuler">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.workbench.texteditor.rulerColumns">
      <column
            class="com._1c.g5.v8.dt.internal.profiling.ui.ProfilingUIExecutableExtensionFactory:com._1c.g5.v8.dt.internal.profiling.ui.ruler.ProfilingResultsRuler"
            enabled="false"
            global="false"
            icon="icons/etool16/profiling.png"
            id="com._1c.g5.v8.dt.profiling.ui.resultsColumn"
            includeInMenu="false"
            name="%ruler.profiling.name">
         <placement
               gravity="1.0">
         </placement>
         <targetEditor
               id="com._1c.g5.v8.dt.bsl.Bsl">
         </targetEditor>
      </column>
   </extension>
   <extension
         point="org.eclipse.ui.trace.traceComponents">
      <component
            id="com._1c.g5.v8.dt.profiling.core.component"
            label="%component.profiling.label">
         <bundle
               consumed="true"
               name="com._1c.g5.v8.dt.profiling.core">
         </bundle>
      </component>
   </extension>
   <extension
         point="org.eclipse.ui.exportWizards">
      <wizard
            category="com._1c.g5.v8.dt.export.ui.exportCategory"
            class="com._1c.g5.v8.dt.internal.profiling.ui.ProfilingUIExecutableExtensionFactory:com._1c.g5.v8.dt.internal.profiling.ui.exportimport.ResultsExportWizard"
            icon="icons/elcl16/profiling_16_export.png"
            id="com._1c.g5.v8.dt.profiling.ui.exportWizard"
            name="%wizard.export.name">
         <description>
            %wizard.export.description
         </description>
      </wizard>
   </extension>
   <extension
         point="org.eclipse.ui.importWizards">
      <wizard
            category="com._1c.g5.v8.dt.import.ui.importCategory"
            class="com._1c.g5.v8.dt.internal.profiling.ui.ProfilingUIExecutableExtensionFactory:com._1c.g5.v8.dt.internal.profiling.ui.exportimport.ResultsImportWizard"
            icon="icons/elcl16/profiling_16_import.png"
            id="com._1c.g5.v8.dt.profiling.ui.importWizard"
            name="%wizard.import.name">
         <description>
            %wizard.import.description
         </description>
      </wizard>
   </extension>
   <extension
         point="org.eclipse.ui.activities">
      	 <activity
		 	description="Hidden View Activity"
			id="com._1c.g5.v8.dt.profiling.ui.activity.compare.view"
			name="Hidden View Activity">
		</activity>
		<activityPatternBinding
			activityId="com._1c.g5.v8.dt.profiling.ui.activity.compare.view"
			isEqualityPattern="true"
			pattern="com._1c.g5.v8.dt.profiling.ui/com._1c.g5.v8.dt.profiling.ui.compare.view">
		</activityPatternBinding>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="com._1c.g5.v8.dt.ui2.perspective">
         <view
               id="com._1c.g5.v8.dt.profiling.ui.view.ProfilingView"
               minimized="false"
               relationship="stack"
               relative="org.eclipse.ui.console.ConsoleView"
               visible="false">
         </view>
      </perspectiveExtension>
      <perspectiveExtension
            targetID="org.eclipse.debug.ui.DebugPerspective">
         <view
               id="com._1c.g5.v8.dt.profiling.ui.view.ProfilingView"
               minimized="false"
               relationship="stack"
               relative="org.eclipse.ui.console.ConsoleView"
               visible="false">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.services">
      <sourceProvider
            provider="com._1c.g5.v8.dt.internal.profiling.ui.PerformanceMenuVariableProvider">
         <variable
               name="com._1c.g5.v8.dt.profiling.ui.showOutdatedResults.active"
               priorityLevel="workbench">
         </variable>
      </sourceProvider>
   </extension>
</plugin>
