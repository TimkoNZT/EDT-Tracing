@ExtendedMetaData(name="CompileError", kind="elementOnly")
class CompileError {
    @ExtendedMetaData(kind="element", name="moduleId", namespace="##targetNamespace")
    String moduleId
    @ExtendedMetaData(kind="element", name="source", namespace="##targetNamespace")
    String[1] source
    @ExtendedMetaData(kind="element", name="message", namespace="##targetNamespace")
    String[1] message
    @ExtendedMetaData(kind="element", name="descr", namespace="##targetNamespace")
    String[1] descr
    @ExtendedMetaData(kind="attribute", name="line")
    BigDecimal line
    @ExtendedMetaData(kind="attribute", name="module")
    String module
    @ExtendedMetaData(kind="attribute", name="pos")
    BigDecimal pos
    @ExtendedMetaData(kind="attribute", name="reason")
    BigDecimal reason
}

@ExtendedMetaData(name="CompileException", kind="elementOnly")
