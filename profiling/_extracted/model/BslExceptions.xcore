    @ExtendedMetaData(kind="element", name="error", namespace="##targetNamespace")
    contains CompileError[] error
}

@ExtendedMetaData(name="RuntimeException", kind="elementOnly")
class RuntimeException extends GenericException {
    @ExtendedMetaData(kind="element", name="moduleId", namespace="##targetNamespace")
    String moduleId
    @ExtendedMetaData(kind="element", name="source", namespace="##targetNamespace")
    String[1] source
