<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <extension point="org.eclipse.ui.views">
      <view
            id="com.nzt.edt.tracing.TraceView"
            name="%view.name"
            class="com.nzt.edt.tracing.view.TraceView"
            category="com._1c.g5.v8.dt.ui.v8category">
      </view>
   </extension>

   <extension point="org.eclipse.ui.commands">
      <command
            id="com.nzt.edt.tracing.commands.toggleTracing"
            name="%command.toggleTracing.name"
            description="%command.toggleTracing.description">
          <state
                class="org.eclipse.ui.handlers.RegistryToggleState:false"
                id="org.eclipse.ui.commands.toggleState">
          </state>
      </command>
   </extension>

   <extension point="org.eclipse.ui.handlers">
      <handler
            commandId="com.nzt.edt.tracing.commands.toggleTracing"
            class="com.nzt.edt.tracing.view.ToggleTracingHandler">
      </handler>
   </extension>

   <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="toolbar:org.eclipse.debug.ui.breakpointActionSet">
         <command
               commandId="com.nzt.edt.tracing.commands.toggleTracing"
               label="%command.toggleTracing.name"
               tooltip="%command.toggleTracing.description"
               icon="icons/tracing.png"
               style="toggle">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.run?after=com._1c.g5.v8.dt.profiling.ui.view.commands.profiling">
         <command
               commandId="com.nzt.edt.tracing.commands.toggleTracing"
               label="%command.toggleTracing.name"
               style="toggle">
         </command>
      </menuContribution>
   </extension>

</plugin>
